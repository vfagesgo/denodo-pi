#cloud-config
manage_resolv_conf: false
hostname: Denodo-PI
manage_etc_hosts: true
package_update: true
packages:
- avahi-daemon
apt:
  preserve_sources_list: true
  conf: |
    Acquire {
      Check-Date "false";
    };
timezone: Europe/Paris
keyboard:
  model: pc105
  layout: "fr"
users:
- name: denodo
  groups: users,adm,dialout,audio,netdev,video,plugdev,cdrom,games,input,gpio,spi,i2c,render,sudo
  shell: /bin/bash
  lock_passwd: false
  passwd: "$y$jB5$LdKQbVrEkwGCqhoIrcJAA/$MkH6PgaNXp1VQHyhdE/Ztfn7TdMskJ8H2V8eTE.xIk7"
enable_ssh: true
ssh_pwauth: true
rpi:
  interfaces:
    serial: true



# Write a wrapper script that loads your .env
write_files:
  - path: /usr/local/bin/bootstrap.sh
    permissions: '0755'
    content: |
      #!/bin/bash
      set -e
      LOG=/var/log/2-bootstrap.log

      echo "[BOOTSTRAP] Starting..."  | tee -a $LOG

      # Load environment variables if present
      if [ -f /boot/firmware/denodo/denodo_config.env ]; then
        echo "[BOOTSTRAP] Loading config from /boot/firmware/denodo/denodo_config.env" | tee -a $LOG
        set -o allexport
        source /boot/firmware/denodo/denodo_config.env
        set +o allexport
      else
        echo "[BOOTSTRAP] No config file found" | tee -a $LOG
      fi

      # Run your main script
      if [ -f /boot/firmware/denodo/denodo_init.sh ]; then
        echo "[BOOTSTRAP] Running denodo_init.sh" | tee -a $LOG
        bash /boot/firmware/denodo/denodo_init.sh
      else
        echo "[BOOTSTRAP] denodo_init.sh not found" | tee -a $LOG
      fi

      echo "[BOOTSTRAP] Done" | tee -a $LOG


# Run at first boot
runcmd:
  - bash /usr/local/bin/bootstrap.sh

output:
  all: "| tee -a /var/log/1-cloud-init-output.log"